{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "ghidra-agent-gui",
  "version": "1.0.1",
  "identifier": "dev.ghidra-agent.gui",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Ghidra Agent GUI",
        "width": 1320,
        "height": 860,
        "minWidth": 980,
        "minHeight": 640,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
