{
  "_comment": "Copy to .mcp.json and fill in any optional credentials. The Ghidra bridge itself needs no secrets — only the optional tooling MCPs (Figma / pixelforge / etc.) do.",
  "mcpServers": {
    "ghidra-agent-mcp": {
      "command": "python",
      "args": ["bridge_lite.py"],
      "env": {
        "GHIDRA_AGENT_MCP_URL": "http://127.0.0.1:18089"
      }
    }
  }
}
